<button class="btt" id="btt" onclick="window.scrollTo({top:0,behavior:'smooth'})">↑</button>

<script>
var SLIDE_COUNT = 4, SLIDE_DURATION = 5500, currentSlide = 0, sliderTimer = null;
var currentLang = 'en';

function goSlide(idx) {
  var slides = document.querySelectorAll('.hs-slide');
  var dots = document.querySelectorAll('.hs-dot');
  slides[currentSlide].classList.remove('active');
  slides[currentSlide].classList.add('prev');
  setTimeout(function(){ slides[currentSlide].classList.remove('prev'); }, 1100);
  currentSlide = (idx + SLIDE_COUNT) % SLIDE_COUNT;
  slides[currentSlide].classList.add('active');
  dots.forEach(function(d,i){ d.classList.toggle('active', i === currentSlide); });
  document.getElementById('hsCur').textContent = String(currentSlide + 1).padStart(2,'0');
  resetSliderTimer();
}
function slideNext(){ goSlide(currentSlide + 1); }
function slidePrev(){ goSlide(currentSlide - 1); }

function resetSliderTimer() {
  clearTimeout(sliderTimer);
  var fill = document.getElementById('hsProgress');
  fill.style.transition = 'none';
  fill.style.width = '0%';
  fill.getBoundingClientRect();
  fill.style.transition = 'width ' + SLIDE_DURATION + 'ms linear';
  fill.style.width = '100%';
  sliderTimer = setTimeout(function(){ goSlide(currentSlide + 1); }, SLIDE_DURATION);
}

document.getElementById('hsSlides').addEventListener('mouseenter', function(){
  clearTimeout(sliderTimer);
  var fill = document.getElementById('hsProgress');
  var computed = parseFloat(getComputedStyle(fill).width);
  var parent = parseFloat(getComputedStyle(fill.parentElement).width);
  fill.style.transition = 'none';
  fill.style.width = (computed / parent * 100) + '%';
});

document.getElementById('hsSlides').addEventListener('mouseleave', function(){
  var fill = document.getElementById('hsProgress');
  var current = parseFloat(fill.style.width);
  var remaining = (100 - current) / 100 * SLIDE_DURATION;
  fill.style.transition = 'width ' + remaining + 'ms linear';
  fill.style.width = '100%';
  sliderTimer = setTimeout(function(){ goSlide(currentSlide + 1); }, remaining);
});

var touchStartX = 0;
document.getElementById('hsSlides').addEventListener('touchstart', function(e){ touchStartX = e.touches[0].clientX; }, {passive:true});
document.getElementById('hsSlides').addEventListener('touchend', function(e){
  var dx = e.changedTouches[0].clientX - touchStartX;
  if (Math.abs(dx) > 50) { dx < 0 ? slideNext() : slidePrev(); }
}, {passive:true});

document.addEventListener('keydown', function(e){
  if (e.key === 'ArrowRight') slideNext();
  if (e.key === 'ArrowLeft') slidePrev();
});

var io = new IntersectionObserver(function(entries) {
  entries.forEach(function(x) {
    if (x.isIntersecting) { x.target.classList.add('vis'); io.unobserve(x.target); }
  });
}, { threshold: 0.07 });
document.querySelectorAll('.rv').forEach(function(el) { io.observe(el); });

window.addEventListener('scroll', function() {
  var sy = window.scrollY;
  document.getElementById('nav').classList.toggle('up', sy > 60);
  document.getElementById('btt').classList.toggle('show', sy > 500);
  var cur = '';
  document.querySelectorAll('section[id]').forEach(function(s) { if (sy >= s.offsetTop - 120) cur = s.id; });
  document.querySelectorAll('.nav-center a').forEach(function(a) { a.classList.toggle('act', a.getAttribute('href') === '#' + cur); });
});

function toggleMenu() { document.getElementById('mobNav').classList.toggle('o'); document.getElementById('ham').classList.toggle('o'); }
function closeMenu() { document.getElementById('mobNav').classList.remove('o'); document.getElementById('ham').classList.remove('o'); }
document.addEventListener('click', function(e) { if (!e.target.closest('#nav') && !e.target.closest('#mobNav')) closeMenu(); });

function handleSubmit(btn) {
  var msg = currentLang === 'en' ? '✓ Message Sent — Thank You!' : '✓ ସନ୍ଦେଶ ପଠାଯାଇଛି — ଧନ୍ୟବାଦ!';
  btn.textContent = msg;
  btn.style.background = '#0A6B04';
  setTimeout(function() { 
    btn.textContent = btn.getAttribute('data-' + currentLang);
    btn.style.background = ''; 
  }, 3500);
}

function setLang(lang, btn) {
  currentLang = lang;
  document.querySelectorAll('.lt-btn').forEach(function(b) { b.classList.remove('active'); });
  btn.classList.add('active');
  document.body.classList.toggle('odia', lang === 'od');
  document.documentElement.lang = lang === 'od' ? 'or' : 'en';
  document.title = lang === 'en' ? 'Rupu Bhatra | MLA Kotpad' : 'ରୁପୁ ଭାତ୍ରା | ବିଧାୟକ କୋଟପାଦ';
  
  document.querySelectorAll('[data-en]').forEach(function(el) {
    var text = el.getAttribute('data-' + lang);
    if (text) {
      if (el.tagName === 'TEXTAREA' || el.tagName === 'INPUT') {
        el.placeholder = text;
      } else {
        el.innerHTML = text;
      }
    }
  });
  
  document.querySelectorAll('option[data-en]').forEach(function(el) {
    var text = el.getAttribute('data-' + lang);
    if (text) el.textContent = text;
  });
}

resetSliderTimer();
setLang('en', document.querySelector('.lt-btn.active'));
</script>
