<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Rupu Bhatra | MLA Kotpad</title>
<link rel="icon" type="image/png" href="https://res.cloudinary.com/dxmdcoca3/image/upload/v1777706234/bjp-kamal-logo_lkqzcp.png">
<link rel="apple-touch-icon" href="https://res.cloudinary.com/dxmdcoca3/image/upload/v1777706234/bjp-kamal-logo_lkqzcp.png">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,300;1,9..144,400&family=Plus+Jakarta+Sans:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
<style>
:root{
  --fire:#FF6A00;--fire2:#E05A00;--fire3:#CC5000;--fire-pale:#FFF3EC;
  --jade:#0A6B04;--jade-pale:#EBF7EA;--gold:#B8860B;--gold-pale:#FEF8E6;
  --ink:#111118;--ink2:#222230;--mid:#5A5A72;--light:#9898A8;
  --border:#EBEBF0;--border2:#D8D8E4;--bg:#FFFFFF;--bg2:#FAFAFA;--bg3:#F5F5F8;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Plus Jakarta Sans','Outfit',sans-serif;background:var(--bg);color:var(--ink);overflow-x:hidden;}
body.odia {font-family:'Fraunces','Outfit',sans-serif;}
::-webkit-scrollbar{width:3px;}
::-webkit-scrollbar-thumb{background:var(--fire);}

/* ── TICKER ── */
#ticker{background:var(--fire);height:36px;display:flex;align-items:center;overflow:hidden;position:relative;z-index:1000;}
.ticker-label{background:var(--fire3);color:#fff;font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;padding:0 1.2rem;height:100%;display:flex;align-items:center;white-space:nowrap;flex-shrink:0;border-right:1px solid rgba(255,255,255,.2);}
.ticker-track-wrap{flex:1;overflow:hidden;height:100%;}
.ticker-track{display:flex;align-items:center;height:100%;animation:tick 22s linear infinite;white-space:nowrap;}
#ticker:hover .ticker-track{animation-play-state:paused;}
.ticker-item{display:flex;align-items:center;gap:.6rem;font-family:'Plus Jakarta Sans',sans-serif;font-size:.78rem;font-weight:600;color:#fff;padding:0 2.5rem;white-space:nowrap;flex-shrink:0;}
.ticker-dot{color:rgba(255,255,255,.4);font-size:1rem;}
@keyframes tick{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── EVENT TICKER ── */
#event-ticker{background:var(--fire2);height:40px;display:flex;align-items:center;overflow:hidden;position:sticky;top:88px;z-index:997;border-bottom:2px solid var(--fire3);}
.et-label{background:var(--fire3);color:#fff;font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;padding:0 1.1rem;height:100%;display:flex;align-items:center;gap:.5rem;white-space:nowrap;flex-shrink:0;border-right:1px solid rgba(255,255,255,.15);}
.et-label-icon{font-size:.85rem;}
.et-track-wrap{flex:1;overflow:hidden;height:100%;}
.et-track{display:flex;align-items:center;height:100%;animation:ettick 30s linear infinite;white-space:nowrap;}
#event-ticker:hover .et-track{animation-play-state:paused;}
.et-item{display:inline-flex;align-items:center;gap:.7rem;font-family:'Plus Jakarta Sans',sans-serif;font-size:.8rem;font-weight:600;color:#fff;padding:0 3rem;white-space:nowrap;flex-shrink:0;}
.et-badge{font-family:'Space Mono',monospace;font-size:.55rem;letter-spacing:.12em;text-transform:uppercase;background:var(--fire3);color:#fff;padding:.2rem .6rem;border-radius:3px;flex-shrink:0;}
.et-sep{color:rgba(255,255,255,.3);font-size:1.2rem;padding:0 1rem;}
@keyframes ettick{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ── NAV ── */
nav{position:sticky;top:0;width:100%;z-index:999;height:88px;display:flex;align-items:center;justify-content:space-between;padding:0 4%;background:rgba(255,255,255,0.97);backdrop-filter:blur(20px);border-bottom:2px solid var(--fire);transition:all .3s;}
nav.up{box-shadow:0 2px 24px rgba(0,0,0,0.08);}
.logo{display:flex;align-items:center;gap:.8rem;text-decoration:none;}
.logo-bjp{height:48px;width:auto;flex-shrink:0;}
.logo-text{display:flex;flex-direction:column;gap:1px;}
.logo-site{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.2em;text-transform:uppercase;color:var(--fire);font-weight:700;}
.logo-name{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:700;color:var(--fire);letter-spacing:-.01em;line-height:1;}
.logo-name em{color:var(--fire);font-style:normal;}
.nav-center{display:flex;gap:2rem;list-style:none;}
.nav-center a{font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.12em;text-transform:uppercase;color:var(--light);text-decoration:none;font-weight:700;transition:color .3s ease;position:relative;padding-bottom:4px;}
.nav-center a::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--fire);transform:scaleX(0);transform-origin:left;transition:transform .3s ease;}
.nav-center a:hover,.nav-center a.act{color:var(--fire);}
.nav-center a:hover::after,.nav-center a.act::after{transform:scaleX(1);}
.nav-right{display:flex;align-items:center;gap:1rem;}
.nav-leaders{display:flex;align-items:center;gap:.6rem;}
.nav-leader{display:flex;flex-direction:column;align-items:center;gap:3px;text-decoration:none;}
.nav-leader img{width:52px;height:56px;border-radius:6px;object-fit:cover;object-position:top center;border:2px solid var(--border);transition:transform .2s,border-color .2s;display:block;}
.nav-leader:hover img{transform:scale(1.06);border-color:var(--fire);}
.nav-sep{width:1px;height:40px;background:var(--border);margin:0 .3rem;}
.lang-toggle{display:flex;align-items:center;gap:0;border:1.5px solid var(--border2);overflow:hidden;border-radius:4px;}
.lt-btn{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.08em;text-transform:uppercase;padding:.4rem .9rem;cursor:pointer;border:none;background:var(--bg3);color:var(--mid);transition:all .2s;font-weight:700;border-right:1px solid var(--border2);}
.lt-btn:last-child{border-right:none;}
.lt-btn.active{background:var(--fire);color:#fff;}
.lt-btn:not(.active):hover{background:var(--fire-pale);color:var(--fire);}
.nav-contact{background:var(--fire);color:#fff;font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;padding:.52rem 1.2rem;text-decoration:none;transition:background .2s;font-weight:700;border-radius:3px;}
.nav-contact:hover{background:var(--fire2);}
.ham{display:none;flex-direction:column;gap:4px;cursor:pointer;padding:4px;}
.ham span{width:20px;height:1.5px;background:var(--ink);display:block;transition:all .3s;}
.ham.o span:nth-child(1){transform:translateY(5.5px) rotate(45deg);}
.ham.o span:nth-child(2){opacity:0;}
.ham.o span:nth-child(3){transform:translateY(-5.5px) rotate(-45deg);}
.mob-nav{display:none;position:fixed;top:124px;left:0;right:0;z-index:998;background:var(--bg);border-bottom:2px solid var(--fire);padding:0 5% 1rem;}
.mob-nav.o{display:flex;flex-direction:column;}
.mob-nav a{font-family:'Space Mono',monospace;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;color:var(--mid);text-decoration:none;padding:.9rem 0;border-bottom:1px solid var(--border);transition:color .2s;font-weight:700;}
.mob-nav a:last-child{color:var(--fire);border:none;}
.mob-nav a:hover{color:var(--fire);}

/* ══ HERO SLIDER ══ */
#hero{position:relative;width:100%;height:calc(100vh - 128px);min-height:520px;overflow:hidden;display:flex;flex-direction:column;}
.hs-slides{flex:1;position:relative;overflow:hidden;}
.hs-slide{position:absolute;inset:0;opacity:0;transition:opacity .9s cubic-bezier(.4,0,.2,1),transform 1.1s cubic-bezier(.4,0,.2,1);transform:scale(1.04);pointer-events:none;will-change:opacity,transform;}
.hs-slide.active{opacity:1;transform:scale(1);pointer-events:all;z-index:2;}
.hs-slide.prev{opacity:0;transform:scale(1.02);z-index:1;}
.hs-bg{position:absolute;inset:0;background-size:cover;background-position:center 20%;transition:transform 6s ease;}
.hs-slide.active .hs-bg{transform:scale(1.06);}
.hs-overlay{position:absolute;inset:0;background:linear-gradient(105deg,rgba(10,10,20,.82) 0%,rgba(10,10,20,.55) 40%,rgba(10,10,20,.15) 70%,transparent 100%);}
.hs-content{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:center;padding:4rem 6%;}
.hs-chip{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--fire);display:inline-flex;align-items:center;gap:.5rem;margin-bottom:1.4rem;font-weight:700;opacity:0;transform:translateY(14px);transition:all .7s ease .3s;}
.hs-slide.active .hs-chip{opacity:1;transform:translateY(0);}
.hs-chip::before{content:'';width:16px;height:1px;background:var(--fire);}
.hs-heading{font-family:'Plus Jakarta Sans','Outfit',sans-serif;font-weight:800;font-style:normal;font-size:clamp(2rem,4.2vw,4.4rem);line-height:1.1;letter-spacing:-.03em;color:#fff;max-width:560px;margin-bottom:1.4rem;opacity:0;transform:translateY(22px);transition:all .75s ease .45s;}
.hs-slide.active .hs-heading{opacity:1;transform:translateY(0);}
.hs-heading .accent{color:var(--fire);}
.hs-sub{font-family:'Plus Jakarta Sans',sans-serif;font-size:1rem;color:rgba(255,255,255,.75);max-width:400px;line-height:1.75;margin-bottom:2rem;opacity:0;transform:translateY(16px);transition:all .7s ease .6s;}
.hs-slide.active .hs-sub{opacity:1;transform:translateY(0);}
.hs-actions{display:flex;gap:.8rem;align-items:center;opacity:0;transform:translateY(14px);transition:all .65s ease .75s;}
.hs-slide.active .hs-actions{opacity:1;transform:translateY(0);}
.hs-btn-primary{background:var(--fire);color:#fff;padding:.82rem 2rem;font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.04em;text-decoration:none;border-radius:3px;transition:all .2s;display:inline-block;}
.hs-btn-primary:hover{background:var(--fire2);transform:translateY(-2px);}
.hs-btn-ghost{color:rgba(255,255,255,.75);font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.1em;text-transform:uppercase;text-decoration:none;display:flex;align-items:center;gap:.5rem;transition:color .2s;font-weight:700;}
.hs-btn-ghost:hover{color:#fff;}
.hs-btn-ghost::after{content:'→';}
.hs-counter{position:absolute;top:2rem;right:2.5rem;z-index:10;font-family:'Space Mono',monospace;font-size:.65rem;letter-spacing:.14em;color:rgba(255,255,255,.5);display:flex;align-items:center;gap:.6rem;}
.hs-counter-cur{font-size:1.2rem;font-weight:700;color:#fff;letter-spacing:0;line-height:1;}
.hs-counter-sep{width:28px;height:1px;background:rgba(255,255,255,.25);}
.hs-counter-tot{color:rgba(255,255,255,.4);}
.hs-progress-bar{position:absolute;top:0;left:0;right:0;height:3px;z-index:10;background:rgba(255,255,255,.1);}
.hs-progress-fill{height:100%;background:var(--fire);width:0%;transition:width linear;}
.hs-arrow{position:absolute;top:50%;transform:translateY(-50%);z-index:10;width:52px;height:52px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:#fff;font-size:1.3rem;cursor:pointer;display:flex;align-items:center;justify-content:center;transition:all .25s;backdrop-filter:blur(6px);}
.hs-arrow:hover{background:var(--fire);border-color:var(--fire);}
.hs-arrow-prev{left:2rem;}
.hs-arrow-next{right:2rem;}
.hs-dots{position:absolute;bottom:2.2rem;right:2.5rem;z-index:10;display:flex;gap:.55rem;align-items:center;}
.hs-dot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.3);cursor:pointer;transition:all .3s;border:1.5px solid rgba(255,255,255,.15);}
.hs-dot.active{background:var(--fire);width:22px;border-radius:4px;border-color:var(--fire);}
.hs-dot:hover{background:rgba(255,255,255,.6);}
.hero-strip{background:var(--fire);padding:.85rem 0;overflow:hidden;position:relative;z-index:1;display:flex;flex-shrink:0;}
.hs-track{display:flex;gap:3rem;align-items:center;animation:marquee 28s linear infinite;flex-shrink:0;white-space:nowrap;}
.hero-strip:hover .hs-track{animation-play-state:paused;}
@keyframes marquee{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}
.hs-item{display:flex;align-items:center;gap:.6rem;white-space:nowrap;flex-shrink:0;}
.hs-n{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:700;color:#fff;}
.hs-l{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:rgba(255,255,255,.7);}
.hs-dot-m{color:rgba(255,255,255,.3);font-size:1.5rem;line-height:1;}

/* ══ SECTIONS ══ */
.s{padding:6rem 8%;}
.s-off{background:var(--bg2);}
.s-dark{background:var(--ink);}
.s-warm{background:var(--fire-pale);}
.lbl{font-family:'Space Mono',monospace;font-size:.66rem;letter-spacing:.22em;text-transform:uppercase;color:var(--fire);display:flex;align-items:center;gap:.6rem;margin-bottom:1rem;font-weight:700;}
.lbl::before{content:'';width:18px;height:1px;background:var(--fire);}
.lbl.inv{color:rgba(255,255,255,.9);}
.lbl.inv::before{background:rgba(255,255,255,.6);}
.sh{font-family:'Fraunces',serif;font-size:clamp(2rem,3.5vw,3.2rem);font-weight:700;letter-spacing:-.02em;line-height:1.1;color:var(--ink);}
.sh .ac{color:var(--fire);}
.sh.inv{color:#fff;}
.ss{font-size:1rem;color:var(--mid);line-height:1.8;max-width:500px;margin-top:.8rem;}
.ss.inv{color:rgba(255,255,255,.75);}
.s-hd{margin-bottom:3.5rem;}

/* ABOUT */
#about .wrap{display:grid;grid-template-columns:300px 1fr;gap:5rem;align-items:start;}
.ab-imgs{display:flex;flex-direction:column;gap:.8rem;}
.ab-img-main{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top center;display:block;border-radius:8px;box-shadow:0 12px 40px rgba(255,106,0,.15);}
.ab-flag{display:flex;height:3px;margin-top:.8rem;}
.ab-flag span{flex:1;}
.ab-flag span:nth-child(1){background:var(--fire);}
.ab-flag span:nth-child(2){background:#ddd;}
.ab-flag span:nth-child(3){background:var(--jade);}
.wiki-card{background:var(--bg3);border:1.5px solid var(--border2);border-radius:6px;padding:1.2rem;margin-top:1rem;font-size:.82rem;}
.wiki-card-title{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.15em;text-transform:uppercase;color:var(--fire);font-weight:700;margin-bottom:.8rem;display:flex;align-items:center;gap:.4rem;}
.wiki-row{display:flex;justify-content:space-between;gap:.8rem;padding:.45rem 0;border-bottom:1px solid var(--border);}
.wiki-row:last-child{border-bottom:none;}
.wiki-k{color:var(--mid);font-size:.8rem;}
.wiki-v{color:var(--ink);font-weight:700;font-size:.8rem;text-align:right;}
.ab-quote{font-family:'Fraunces',serif;font-size:1.5rem;font-style:italic;font-weight:400;color:var(--ink);line-height:1.5;border-left:3px solid var(--fire);padding-left:1.5rem;margin-bottom:2rem;}
.ab-body{font-size:.98rem;color:var(--mid);line-height:1.95;margin-bottom:1rem;}
.ab-grid{display:grid;grid-template-columns:1fr 1fr;gap:.6rem;margin-top:2rem;}
.ab-fact{padding:.85rem 1rem;background:var(--bg3);border-bottom:2px solid transparent;transition:border-color .2s;border-radius:3px;}
.ab-fact:hover{border-bottom-color:var(--fire);}
.ab-k{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.12em;text-transform:uppercase;color:var(--fire);margin-bottom:.25rem;font-weight:700;}
.ab-v{font-size:.9rem;font-weight:700;color:var(--ink);}

/* VISION */
#vision .vwrap{display:grid;grid-template-columns:1fr 2fr;gap:5rem;align-items:start;}
#vision .vright{display:grid;grid-template-columns:1fr 1fr;gap:1px;background:var(--border);}
.vc{background:var(--bg);padding:2rem 1.8rem;position:relative;overflow:hidden;cursor:default;transition:background .25s;}
.vc:hover{background:var(--fire-pale);}
.vc-n{font-family:'Fraunces',serif;font-size:4rem;font-weight:700;color:rgba(255,106,0,.06);line-height:1;position:absolute;top:.8rem;right:1rem;}
.vc-icon{font-size:1.8rem;margin-bottom:1rem;display:block;}
.vc-title{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:600;color:var(--ink);margin-bottom:.6rem;}
.vc-text{font-size:.88rem;color:var(--mid);line-height:1.8;}
.vc-bar{position:absolute;bottom:0;left:0;width:0;height:2px;background:var(--fire);transition:width .4s;}
.vc:hover .vc-bar{width:100%;}

/* JOURNEY */
#journey .jlayout{display:grid;grid-template-columns:300px 1fr;gap:6rem;align-items:start;}
#journey .jleft{position:sticky;top:8rem;}
.jl-n{font-family:'Fraunces',serif;font-size:7rem;font-weight:700;color:var(--fire);line-height:1;opacity:.12;}
.jl-img{width:100%;aspect-ratio:3/4;object-fit:cover;object-position:top;display:block;margin-top:-3rem;border-radius:6px;}
.jright{display:flex;flex-direction:column;gap:0;}
.je{display:grid;grid-template-columns:80px 1fr;gap:1.5rem;padding:2rem 0;border-bottom:1px solid var(--border);transition:background .2s,padding .2s;cursor:default;}
.je:first-child{padding-top:0;}
.je:last-child{border-bottom:none;}
.je:hover{background:var(--bg2);padding-left:1rem;padding-right:1rem;margin:0 -1rem;}
.je-yr{font-family:'Space Mono',monospace;font-size:.68rem;letter-spacing:.12em;color:var(--fire);padding-top:.4rem;font-weight:700;}
.je-title{font-family:'Fraunces',serif;font-size:1.1rem;font-weight:600;color:var(--ink);margin-bottom:.4rem;}
.je-desc{font-size:.88rem;color:var(--mid);line-height:1.75;}
.je:last-child .je-yr{color:var(--gold);}
.je:last-child .je-title{color:var(--gold);}

/* ACHIEVEMENTS */
#achievements{background:var(--fire);}
#achievements .iheader{display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:end;margin-bottom:4rem;}
.i-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1px;background:rgba(255,255,255,.2);}
.i-row2{grid-template-columns:repeat(4,1fr);}
.it{background:var(--fire);padding:2.2rem 1.5rem;text-align:center;position:relative;overflow:hidden;transition:background .3s;cursor:default;}
.it:hover{background:var(--fire2);}
.it-icon{font-size:1.6rem;margin-bottom:.7rem;display:block;}
.it-n{font-family:'Fraunces',serif;font-size:2.6rem;font-weight:700;color:#fff;line-height:1;margin-bottom:.2rem;}
.it-n sup{font-size:1.3rem;}
.it-l{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.65);}
.it::after{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:rgba(255,255,255,.4);transform:scaleX(0);transition:transform .3s;}
.it:hover::after{transform:scaleX(1);}
.awards{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(255,255,255,.2);margin-top:1px;}
.aw{background:var(--fire2);padding:2rem;display:flex;gap:1.2rem;transition:background .3s;}
.aw:hover{background:rgba(212,90,10,.9);}
.aw-icon{font-size:1.8rem;flex-shrink:0;}
.aw-yr{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:rgba(255,255,255,.6);margin-bottom:.25rem;}
.aw-t{font-family:'Fraunces',serif;font-size:1.05rem;font-weight:600;color:#fff;margin-bottom:.3rem;}
.aw-b{font-size:.85rem;color:rgba(255,255,255,.65);line-height:1.65;}

/* PRESS */
#press .playout{display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:1.5rem;}
.pc{background:var(--bg);border:1px solid var(--border);padding:2rem;transition:all .3s;position:relative;border-radius:4px;}
.pc:hover{border-color:var(--fire);transform:translateY(-2px);box-shadow:0 8px 32px rgba(0,0,0,.07);}
.pc.big{grid-row:span 2;display:flex;flex-direction:column;justify-content:space-between;}
.pc-src{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.15em;text-transform:uppercase;color:var(--fire);margin-bottom:.8rem;display:flex;align-items:center;gap:.4rem;font-weight:700;}
.pc-src::before{content:'';width:12px;height:1px;background:var(--fire);display:block;}
.pc-hl{font-family:'Fraunces',serif;font-size:1rem;font-weight:500;color:var(--ink);line-height:1.55;margin-bottom:.6rem;}
.pc.big .pc-hl{font-size:1.3rem;line-height:1.4;}
.pc-dt{font-family:'Space Mono',monospace;font-size:.62rem;color:var(--light);}
.pc::after{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--fire);transform:scaleX(0);transform-origin:left;transition:transform .3s;}
.pc:hover::after{transform:scaleX(1);}

/* CONTACT */
#contact{display:grid;grid-template-columns:1fr 1fr;padding:0;min-height:640px;align-items:stretch;}
.ct-l{background:var(--bg3);padding:5rem 6% 5rem 6%;border-right:1px solid var(--border);}
.ct-mail-cta{margin-top:2.5rem;padding:1.8rem 2rem;background:var(--fire-pale);border-left:3px solid var(--fire);display:flex;flex-direction:column;gap:.9rem;}
.ct-mail-label{font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;color:var(--fire);font-weight:700;}
.ct-mail-addr{font-family:'Fraunces',serif;font-size:1.15rem;font-weight:600;color:var(--ink);word-break:break-all;line-height:1.3;}
.ct-mail-btn{display:inline-flex;align-items:center;gap:.55rem;background:var(--fire);color:#fff;font-family:'Outfit',sans-serif;font-size:.88rem;font-weight:700;letter-spacing:.04em;padding:.72rem 1.5rem;text-decoration:none;align-self:flex-start;transition:background .2s,transform .2s;border-radius:3px;}
.ct-mail-btn:hover{background:var(--fire2);transform:translateY(-2px);}
.ct-r{padding:5rem 6% 5rem 5%;background:var(--bg);}
.ct-name{font-family:'Fraunces',serif;font-size:2.4rem;font-weight:700;letter-spacing:-.02em;color:var(--ink);line-height:1.1;margin-bottom:.8rem;}
.ct-name em{color:var(--fire);font-style:normal;}
.ct-desc{font-size:.97rem;color:var(--mid);line-height:1.85;margin-bottom:2.5rem;}
.ci{display:flex;gap:1rem;align-items:flex-start;padding:1rem 0;border-bottom:1px solid var(--border);}
.ci:last-of-type{border-bottom:none;}
.ci-ico{width:38px;height:38px;background:var(--fire-pale);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;border-radius:4px;}
.ci-k{font-family:'Space Mono',monospace;font-size:.58rem;letter-spacing:.14em;text-transform:uppercase;color:var(--fire);margin-bottom:.18rem;font-weight:700;}
.ci-v{font-size:.87rem;color:var(--ink);font-weight:600;word-break:break-word;}
.soc{display:flex;gap:.5rem;margin-top:2rem;flex-wrap:wrap;}
.sb{width:40px;height:40px;border:1.5px solid var(--border);background:var(--bg);color:var(--mid);display:flex;align-items:center;justify-content:center;font-size:.88rem;font-weight:700;text-decoration:none;transition:all .2s;border-radius:4px;}
.sb:hover{background:var(--fire);color:#fff;border-color:var(--fire);}
.cf-title{font-family:'Fraunces',serif;font-size:1.8rem;font-weight:700;color:var(--ink);margin-bottom:.4rem;letter-spacing:-.02em;}
.cf-sub{font-size:.9rem;color:var(--mid);margin-bottom:2rem;}
.fg{margin-bottom:1.1rem;}
.fr2{display:grid;grid-template-columns:1fr 1fr;gap:1.1rem;}
.fl{display:block;font-family:'Space Mono',monospace;font-size:.6rem;letter-spacing:.12em;text-transform:uppercase;color:var(--mid);margin-bottom:.4rem;font-weight:700;}
.fi,.fse,.ft{width:100%;padding:.78rem 1rem;border:1.5px solid var(--border);background:var(--bg);font-family:'Outfit',sans-serif;font-size:1rem;color:var(--ink);outline:none;appearance:none;transition:border-color .2s;border-radius:3px;}
.fi:focus,.fse:focus,.ft:focus{border-color:var(--fire);}
.fse option{background:var(--bg);}
.ft{resize:vertical;min-height:90px;}
.fb{width:100%;padding:.95rem;background:var(--fire);color:#fff;border:none;font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:700;letter-spacing:.06em;cursor:pointer;transition:background .2s;border-radius:3px;}
.fb:hover{background:var(--fire2);}

/* FOOTER */
footer{background:var(--ink2);}
.ft-main{display:grid;grid-template-columns:2fr 1fr 1fr;gap:3rem;padding:4rem 8% 3rem;border-bottom:1px solid rgba(255,255,255,.07);}
.fb-brand{font-family:'Fraunces',serif;font-size:1.5rem;font-weight:700;color:#fff;margin-bottom:.6rem;}
.fb-brand em{color:var(--fire);font-style:normal;}
.fb-tag{font-size:.88rem;color:rgba(255,255,255,.35);line-height:1.7;max-width:250px;}
.fb-flag{display:flex;height:2px;width:56px;margin-top:1.2rem;}
.fb-flag span{flex:1;}
.fb-flag span:nth-child(1){background:var(--fire);}
.fb-flag span:nth-child(2){background:rgba(255,255,255,.2);}
.fb-flag span:nth-child(3){background:var(--jade);}
.fc-t{font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--fire);margin-bottom:1.1rem;font-weight:700;}
.fl-links{list-style:none;display:flex;flex-direction:column;gap:.5rem;}
.fl-links a{font-size:.88rem;color:rgba(255,255,255,.35);text-decoration:none;transition:color .2s;}
.fl-links a:hover{color:#fff;}
.ft-bot{display:flex;justify-content:space-between;align-items:center;padding:1.5rem 8%;font-family:'Space Mono',monospace;font-size:.62rem;letter-spacing:.08em;color:rgba(255,255,255,.25);flex-wrap:wrap;gap:.4rem;}

/* UTILS */
.rv{opacity:0;transform:translateY(22px);transition:opacity .7s ease,transform .7s ease;}
.rv.vis{opacity:1;transform:translateY(0);}
.d1{transition-delay:.1s;}.d2{transition-delay:.2s;}.d3{transition-delay:.3s;}
.btt{position:fixed;bottom:2rem;right:1.5rem;z-index:800;width:42px;height:42px;background:var(--fire);color:#fff;border:none;font-size:1rem;cursor:pointer;box-shadow:0 4px 18px rgba(255,106,0,.35);transition:all .3s;opacity:0;transform:translateY(8px);pointer-events:none;border-radius:4px;}
.btt.show{opacity:1;transform:translateY(0);pointer-events:all;}
.btt:hover{background:var(--fire2);}

.mob-sticky{display:none;position:fixed;bottom:0;left:0;right:0;z-index:900;background:#fff;border-top:2px solid var(--fire);padding:.7rem 1rem calc(.7rem + env(safe-area-inset-bottom));gap:.7rem;box-shadow:0 -4px 20px rgba(0,0,0,.08);}
.ms-btn{flex:1;display:flex;align-items:center;justify-content:center;gap:.4rem;padding:.8rem;font-family:'Outfit',sans-serif;font-size:.9rem;font-weight:700;text-decoration:none;transition:all .2s;border-radius:3px;}
.ms-call{background:var(--bg3);color:var(--ink);border:1.5px solid var(--border);}
.ms-write{background:var(--fire);color:#fff;}
@media(max-width:768px){.mob-sticky{display:flex;}footer{padding-bottom:calc(2rem + 76px + env(safe-area-inset-bottom))!important;}#contact .ct-r{padding-bottom:calc(6rem + 80px);}}

